# =========================
# Spring Profile
# =========================
# Default profile is `local` (set in application.yml).
# Uncomment to switch profile explicitly.
# SPRING_PROFILES_ACTIVE=local

# =========================
# Local Profile (`local`)
# Used by: application-local.yml
# =========================
DB_URL=jdbc:mysql://localhost:3306/course_registration?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=your_local_db_user
DB_PASSWORD=your_local_db_password
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# =========================
# Dev Profile (`dev`)
# Used by: application-dev.yml
# =========================
DEV_DB_URL=jdbc:mysql://dev-host:3306/course_registration?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DEV_DB_USERNAME=your_dev_db_user
DEV_DB_PASSWORD=your_dev_db_password
DEV_DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# =========================
# Prod Profile (`prod`)
# Used by: application-prod.yml
# =========================
PROD_DB_URL=jdbc:mysql://prod-host:3306/course_registration?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
PROD_DB_USERNAME=your_prod_db_user
PROD_DB_PASSWORD=your_prod_db_password
PROD_DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
